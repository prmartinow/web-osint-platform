TYPESENSE_API_KEY=replace-with-generated-secret
CLICKHOUSE_PASSWORD=replace-with-generated-secret
WEB_OSINT_REPO_ROOT=/opt/web-osint-platform
WEB_OSINT_DATA_ROOT=/srv/web-osint-platform/data
WEB_OSINT_DASHBOARD_BIND=replace-with-bind-host
WEB_OSINT_CPU_RESERVED_THREADS=2

# Local inference API interface. Model serving and downloads live in
# prmartinow/local-inference.
LOCAL_INFERENCE_URL=https://local-inference.example.invalid
WEB_OSINT_EMBEDDING_WORKER_VENV=/srv/web-osint-platform/.venv-embedding-worker
WEB_OSINT_MEDIA_ENRICHMENT_VENV=/srv/web-osint-platform/.venv-media-enrichment
WEB_OSINT_WEBPAGE_EXTRACTION_VENV=/srv/web-osint-platform/.venv-webpage-extraction
EMBEDDING_WORKER_URL=https://embedding-worker.example.invalid
MEDIA_ROUTER_URL=https://media-router.example.invalid
MEDIA_OCR_WORKER_URL=https://media-ocr-worker.example.invalid
MEDIA_VL_WORKER_URL=https://media-vl-worker.example.invalid
WEBPAGE_EXTRACTION_WORKER_URL=https://webpage-extraction-worker.example.invalid
NORMALIZER_URL=https://normalizer.example.invalid
RESEARCH_PLANNER_URL=https://research-planner.example.invalid
REDPANDA_BROKERS=kafka.example.invalid:9092
KAFKA_BROKERS=kafka.example.invalid:9092
PANDAPROXY_URL=https://pandaproxy.example.invalid
CLICKHOUSE_URL=https://clickhouse.example.invalid
TYPESENSE_URL=https://typesense.example.invalid
QDRANT_URL=https://qdrant.example.invalid
QDRANT_TEXT_VECTOR_SIZE=4096
QDRANT_VL_VECTOR_SIZE=4096
QDRANT_RECREATE_EMPTY_ON_VECTOR_MISMATCH=false

# Public deployment-shape knobs. Values here are examples only; production
# deployment values belong in an ignored .env file or a secret manager.
WEB_OSINT_CONTAINER_PREFIX=web-osint
CLICKHOUSE_DATABASE=web_osint
CLICKHOUSE_USER=web_osint
WEB_OSINT_RESEARCH_UI_BIND=replace-with-bind-host
WEB_OSINT_EMIT_OBSERVED_TOPICS=true

# Do not add model root, model name, model download, or model-serving variables
# here. Web OSINT is a client of the local-inference API, not a model owner.

# Optional Research UI -> Rebrowser launch bridge. Set the real helper endpoint
# only in an ignored deployment env file or secret manager.
REBROWSER_LAUNCH_URL=https://rebrowser-launcher.example.invalid/launch

# Optional collectors that run against an operator-owned Rebrowser session and
# publish through an RPC-local Pandaproxy. Real values belong outside Git.
REBROWSER_CDP_URL=https://rebrowser-cdp.example.invalid
REBROWSER_X_HELPERS=/path/to/local/red_x_slow_helpers.mjs
WEB_OSINT_RPC_SSH_HOST=web-osint-rpc.example
WEB_OSINT_RPC_SSH_PORT=22
WEB_OSINT_RPC_DATA_ROOT=/srv/web-osint-platform
WEB_OSINT_REMOTE_PANDAPROXY_URL=https://pandaproxy.example.invalid
WEB_OSINT_X_EXPECTED_ACCOUNT=replace-with-account-handle
