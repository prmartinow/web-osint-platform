{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Web OSINT Web Document Observation",
  "type": "object",
  "required": ["schema_version", "collector_run_id", "source_project", "capture_method", "captured_at", "canonical_url"],
  "properties": {
    "schema_version": {"const": "v1"},
    "observation_id": {"type": "string"},
    "collector_run_id": {"type": "string", "minLength": 1},
    "source_project": {"type": "string"},
    "capture_method": {"type": "string"},
    "captured_at": {"type": "string", "format": "date-time"},
    "document_id": {"type": "string"},
    "evidence_id": {"type": "string"},
    "evidence_document_id": {"type": "string"},
    "evidence_document_path": {"type": "string"},
    "canonical_url": {"type": "string"},
    "domain": {"type": "string"},
    "title": {"type": "string"},
    "text": {"type": "string"},
    "text_hash": {"type": "string"},
    "content_type": {"type": "string"},
    "document_kind": {"type": "string"},
    "published_at": {"type": ["string", "null"], "format": "date-time"},
    "links": {"type": "array", "items": {"type": "string"}},
    "media_ids": {"type": "array", "items": {"type": "string"}},
    "topics": {"type": "array", "items": {"type": "string"}},
    "entities": {"type": "array", "items": {"type": "string"}},
    "artifact_paths": {"type": "array", "items": {"type": "string"}},
    "content_representations": {"type": "object"},
    "capture_bundle": {"type": "object"},
    "tables": {"type": "array"},
    "quality": {"type": "object"},
    "vectors": {"type": "object"},
    "raw": {"type": "object"}
  },
  "additionalProperties": true
}
