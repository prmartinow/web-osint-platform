[Unit]
Description=Web OSINT Qwen3-VL media embedding worker
Documentation=file:/home/ops/dev/x-research/docs/LOCAL_INFERENCE.md
After=network-online.target local-inference.service web-osint-media-router.service
Wants=network-online.target local-inference.service

[Service]
Type=simple
WorkingDirectory=/home/ops/dev/x-research
EnvironmentFile=-/home/ops/dev/x-research/.env
Environment=OSINT_DATA_ROOT=/mnt/data/x-research
Environment=WEB_OSINT_MODEL_ROOT=/mnt/data/web-osint-platform
Environment=WEB_OSINT_CPU_RESERVED_THREADS=2
Environment=REDPANDA_BROKERS=127.0.0.1:19092
Environment=KAFKA_BROKERS=127.0.0.1:19092
Environment=CLICKHOUSE_URL=http://127.0.0.1:18123
Environment=CLICKHOUSE_DATABASE=web_osint
Environment=CLICKHOUSE_USER=web_osint
Environment=LOCAL_INFERENCE_URL=http://127.0.0.1:18200
Environment=QDRANT_URL=http://127.0.0.1:16333
Environment=QDRANT_COLLECTION=web_osint_evidence_v1
Environment=MEDIA_WORKER_ROLE=vl
Environment=MEDIA_VL_HTTP_ADDR=127.0.0.1:18213
Environment=PADDLE_PDX_CACHE_HOME=/mnt/data/web-osint-platform/paddleocr/paddlex-cache
Environment=PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
Environment=TOKENIZERS_PARALLELISM=false
ExecStartPre=/home/ops/dev/x-research/scripts/init_media_enrichment_venv.sh
ExecStart=/home/ops/dev/x-research/scripts/run_with_cpu_thread_guard.sh /mnt/data/web-osint-platform/.venv-media-enrichment/bin/python /home/ops/dev/x-research/workers/media-enrichment/media_enrichment_worker.py vl
Restart=on-failure
RestartSec=20

[Install]
WantedBy=default.target
