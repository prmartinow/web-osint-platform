TYPESENSE_API_KEY=replace-with-generated-secret
CLICKHOUSE_PASSWORD=replace-with-generated-secret
WEB_OSINT_DATA_ROOT=/mnt/data/web-osint-platform
WEB_OSINT_DASHBOARD_BIND=127.0.0.1
WEB_OSINT_CPU_RESERVED_THREADS=2

# Local inference defaults.
# Qwen3-Embedding-8B and Qwen3-VL-Embedding-8B expose 4096-dim native vectors.
WEB_OSINT_TEXT_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
WEB_OSINT_RERANKER_MODEL=Qwen/Qwen3-Reranker-8B
WEB_OSINT_VL_EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-8B
WEB_OSINT_MODELS_DIR=/mnt/data/web-osint-platform/models
WEB_OSINT_HF_VENV=/mnt/data/web-osint-platform/.venv-hf
QDRANT_TEXT_VECTOR_SIZE=4096
QDRANT_VL_VECTOR_SIZE=4096
QDRANT_RECREATE_EMPTY_ON_VECTOR_MISMATCH=false
